        nsnewsslider_sliderjsslider {
            iconIdentifier = ns_news_slider-plugin-nsnewsslider
            title = LLL:EXT:ns_news_slider/Resources/Private/Language/locallang_db.xlf:tx_ns_news_slider_domain_model_nsnewsslider.slidejsSlider
